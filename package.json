{
  "name": "festiva",
  "version": "1.0.0",
  "description": "Logiciel de gestion de salle des fêtes — Algérie",
  "author": "Yanis",
  "main": "electron/main.js",
  "homepage": "./",

  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "electron-dev": "concurrently \"set BROWSER=none&& react-scripts start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "react-scripts build && electron-builder",
    "test": "react-scripts test"
  },

  "build": {
    "appId": "dz.festiva.app",
    "productName": "Ma Salle — Gestion Salle des Fêtes",

    "extraMetadata": {
      "main": "electron/main.js"
    },

    "directories": {
      "output": "dist"
    },

    "files": [
      "build/**/*",
      "electron/**/*",
      "database/**/*",
      "node_modules/**/*",
      "package.json"
    ],

    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "fr-FR"
      ]
    }
  },

  "dependencies": {
    "@fullcalendar/core": "^6.1.10",
    "@fullcalendar/daygrid": "^6.1.10",
    "@fullcalendar/interaction": "^6.1.10",
    "@fullcalendar/react": "^6.1.10",
    "@fullcalendar/timegrid": "^6.1.10",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "date-fns": "^3.3.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.2",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.2",
    "zustand": "^4.5.2"
  },

  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "wait-on": "^7.2.0"
  },

  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}